# ============================================================
# 环境变量模板 - 复制此文件为 .env 并填写真实值
# 切勿将 .env 提交到版本控制！
# ============================================================

# ── 应用基础配置 ──────────────────────────────────────────────
FLASK_ENV=production
# 使用 python -c "import secrets; print(secrets.token_hex(32))" 生成
SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX_STRING

# ── 数据库（MySQL 8） ──────────────────────────────────────────
# Docker Compose 内部使用 mysql 作为主机名
DATABASE_URL=mysql://root:REPLACE_DB_PASSWORD@mysql:3306/spare_parts_db?charset=utf8mb4
MYSQL_ROOT_PASSWORD=REPLACE_DB_PASSWORD
MYSQL_DATABASE=spare_parts_db
# 宿主机映射端口（本地开发时直连）
MYSQL_PORT=3306

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:REPLACE_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=REPLACE_REDIS_PASSWORD
REDIS_PORT=6379
USE_REDIS=true

# ── Gunicorn 横向扩展参数 ─────────────────────────────────────
# worker 数量：建议 CPU核数×2+1（单容器），多容器时设为 2-4
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_WORKER_CLASS=sync
GUNICORN_LOG_LEVEL=info

# ── Docker Compose 服务端口 ───────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_REPLICAS=2

# ── 镜像标签 ──────────────────────────────────────────────────
IMAGE_TAG=latest

# ── AI 服务（可选） ───────────────────────────────────────────
SILICONFLOW_API_KEY=
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_IMAGE_API_KEY=
BAIDU_IMAGE_SECRET_KEY=
BAIDU_IMAGE_MODEL=stable-diffusion-xl
QIANFAN_MODEL=ERNIE-Bot-4.0

# ── 邮件通知（可选） ──────────────────────────────────────────
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@example.com
