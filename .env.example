# 硅基流动 API 密钥配置
# 请将此文件复制为 .env 并填入您的实际 API 密钥

# ===========================================
# 硅基流动 AI 配置
# ===========================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# ===========================================
# 百度千帆 AI 配置（用于 AI 推荐功能）
# ===========================================
# 获取方式：https://console.bce.baidu.com/qianfan/
QIANFAN_API_KEY=your_baidu_api_key_here
QIANFAN_SECRET_KEY=your_baidu_secret_key_here
QIANFAN_MODEL=ERNIE-Bot-4.0

# ===========================================
# 百度图像生成 API 配置（可选）
# ===========================================
# 获取方式：https://cloud.baidu.com/product/ai/image_generation
BAIDU_IMAGE_API_KEY=your_baidu_image_api_key_here
BAIDU_IMAGE_SECRET_KEY=your_baidu_image_secret_key_here
BAIDU_IMAGE_MODEL=stable-diffusion-v1-5

# ===========================================
# 其他 AI 服务配置（可选）
# ===========================================
# 如果使用其他 AI 服务，在此添加配置
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=sqlite:///app/spare_parts.db
# 或使用 MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/spare_management

# ===========================================
# 应用配置
# ===========================================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-please-change-in-production

# ===========================================
# 安全配置
# ===========================================
# CSRF 保护（生产环境建议启用）
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600

# ===========================================
# 文件上传配置
# ===========================================
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp

# ===========================================
# 缓存配置（可选）
# ===========================================
# CACHE_TYPE=redis
# CACHE_REDIS_URL=redis://localhost:6379/0
# CACHE_DEFAULT_TIMEOUT=300

# ===========================================
# 邮件配置（可选）
# ===========================================
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@example.com
# MAIL_PASSWORD=your_email_password
# MAIL_USE_TLS=True

# ===========================================
# 部署配置（生产环境）
# ===========================================
# 生产环境请修改以下配置
# FLASK_ENV=production
# FLASK_DEBUG=False
# DATABASE_URL=你的生产数据库连接字符串
# SECRET_KEY=使用强随机密钥
